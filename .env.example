# ============================================================================
# CineFlow AI Environment Configuration
# Copy this file to .env and update with your actual values
# ============================================================================

# ============================================================================
# General Configuration
# ============================================================================
ENVIRONMENT=development
LOG_LEVEL=info
DEBUG=false

# ============================================================================
# API Gateway
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_HTTPS_PORT=8443
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
API_RATE_LIMIT_PER_MINUTE=1000

# ============================================================================
# Frontend
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8000/graphql
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_ENVIRONMENT=development

# ============================================================================
# Database - PostgreSQL
# ============================================================================
DATABASE_URL=postgresql://cineflow:cineflow_dev@localhost:5432/cineflow_db
DATABASE_POOL_SIZE=20
DATABASE_POOL_MIN_IDLE=5
DATABASE_POOL_CONNECTION_TIMEOUT=30

# ============================================================================
# Cache - Redis
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_POOL_SIZE=10

# ============================================================================
# Graph Database - Neo4j
# ============================================================================
NEO4J_URL=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=cineflow_dev

# ============================================================================
# Vector Database - Qdrant
# ============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=qdrant_dev_key

# ============================================================================
# Search - Elasticsearch
# ============================================================================
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# ============================================================================
# Object Storage - S3/MinIO
# ============================================================================
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=cineflow-assets
S3_REGION=us-west-2
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_USE_PATH_STYLE=true

# ============================================================================
# Message Queue - Kafka
# ============================================================================
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_PREFIX=cineflow
KAFKA_CONSUMER_GROUP=cineflow

# ============================================================================
# Message Queue - NATS
# ============================================================================
NATS_URL=nats://localhost:4222

# ============================================================================
# Workflow Orchestration - Temporal
# ============================================================================
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=cineflow

# ============================================================================
# Authentication & JWT
# ============================================================================
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30

# ============================================================================
# OAuth Providers
# ============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback/github

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/callback/microsoft

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=http://localhost:3000/auth/callback/apple

# ============================================================================
# AI/ML Services
# ============================================================================
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=4096

ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-3-opus

GOOGLE_PALM_API_KEY=

# ============================================================================
# Video Generation Services
# ============================================================================
RUNWAY_API_KEY=
RUNWAY_MODEL=gen2

LUMA_API_KEY=
LUMA_MODEL=dream-machine

PIKA_API_KEY=

STABLE_DIFFUSION_API_KEY=

# ============================================================================
# Voice & Audio Services
# ============================================================================
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

GOOGLE_TTS_API_KEY=

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

AWS_POLLY_REGION=us-west-2

# ============================================================================
# Monitoring & Observability
# ============================================================================
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=true

GRAFANA_URL=http://localhost:3001
GRAFANA_ADMIN_PASSWORD=admin

JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
JAEGER_ENABLED=true

# ============================================================================
# Email & Notifications
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@cineflow.ai

# ============================================================================
# Slack Integration
# ============================================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=

# ============================================================================
# Security
# ============================================================================
ENCRYPTION_KEY=your-encryption-key-change-in-production
SESSION_SECRET=your-session-secret-change-in-production
CORS_ENABLED=true
CORS_CREDENTIALS=true

# ============================================================================
# Billing & Monetization
# ============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_INTERACTIVE_MODE=true
FEATURE_MULTIPLAYER=false
FEATURE_VOICE_INTERACTION=true
FEATURE_GESTURE_DETECTION=false
FEATURE_VR_MODE=false

# ============================================================================
# Rate Limits & Quotas
# ============================================================================
VIDEO_GENERATION_QUOTA_MONTHLY=100
VOICE_GENERATION_QUOTA_MONTHLY=1000
API_CALLS_QUOTA_MONTHLY=100000
STORAGE_QUOTA_GB=1000

# ============================================================================
# Development Settings
# ============================================================================
MOCK_EXTERNAL_SERVICES=false
DISABLE_AUTH_FOR_DEV=false
VERBOSE_LOGGING=false
ENABLE_PROFILING=false

# ============================================================================
# AWS Configuration (for production)
# ============================================================================
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================================================
# Azure Configuration (optional)
# ============================================================================
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_TENANT_ID=

# ============================================================================
# DataDog (optional monitoring)
# ============================================================================
DATADOG_API_KEY=
DATADOG_ENABLED=false

# ============================================================================
# Sentry Error Tracking
# ============================================================================
SENTRY_DSN=
SENTRY_ENABLED=false

# ============================================================================
# Application URLs
# ============================================================================
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
DOCS_URL=http://localhost:8000/docs
ADMIN_URL=http://localhost:3001
